<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme used by the manifest.
         The actual Material3 theming is applied in Compose code.
         This just provides a minimal XML theme so the Activity can launch. -->
    <style name="Theme.Octomil" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>
